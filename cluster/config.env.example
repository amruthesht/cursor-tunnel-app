# Remote cluster settings (lives at ~/cursor-tunnel/config.env)

SLURM_PARTITION=public
SLURM_ACCOUNT=
SLURM_QOS=public
CPUS=4
MEM=8G
TIME=04:00:00
JOB_PREFIX=cursor-tun-app

TUNNEL_NAME=
TUNNEL_AUTH_PROVIDER=github

CURSOR_TUNNEL_HOME="${HOME}/cursor-tunnel"
CURSOR_BIN="${HOME}/cursor-tunnel/cursor"
